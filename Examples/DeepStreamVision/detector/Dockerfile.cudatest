# Simple CUDA test container based on working PyTorchGPU example
# Uses Ubuntu 22.04 like the working example
FROM ubuntu:22.04

ENV DEBIAN_FRONTEND=noninteractive

# Install only minimal dependencies
RUN apt-get update && apt-get install -y \
    python3 \
    python3-pip \
    && rm -rf /var/lib/apt/lists/*

WORKDIR /app

# Copy only the test script
COPY cuda-test.py /app/

RUN chmod +x /app/cuda-test.py

ENV PYTHONUNBUFFERED=1

# Run the simple CUDA test
CMD ["python3", "/app/cuda-test.py"]
