<?xml version="1.0" encoding="UTF-8"?>
<Wix xmlns="http://wixtoolset.org/schemas/v4/wxs">
  <Package Name="Wendy Tools"
           Manufacturer="Wendy Labs"
           Version="$(var.Version)"
           UpgradeCode="DF463C62-B437-4937-99A0-5CF2441EF919"
           Scope="perMachine"
           InstallerVersion="500">

    <SummaryInformation Description="Wendy CLI - Remote device debugging and deployment"
                        Manufacturer="Wendy Labs" />

    <MajorUpgrade DowngradeErrorMessage="A newer version of Wendy Tools is already installed."
                  AllowSameVersionUpgrades="yes" />

    <MediaTemplate EmbedCab="yes" CompressionLevel="high" />

    <!-- Directory structure -->
    <StandardDirectory Id="ProgramFiles64Folder">
      <Directory Id="ManufacturerFolder" Name="Wendy Labs">
        <Directory Id="INSTALLFOLDER" Name="Wendy Tools" />
      </Directory>
    </StandardDirectory>

    <!-- Files from the staging directory -->
    <ComponentGroup Id="ProductComponents" Directory="INSTALLFOLDER">
      <Files Include="$(var.SourceDir)\*.*" />
    </ComponentGroup>

    <!-- PATH environment variable -->
    <Component Id="PathEnv" Directory="INSTALLFOLDER" Guid="A1B2C3D4-E5F6-47A8-9ABC-0123456789AB">
      <Environment Id="PATH" Name="PATH" Value="[INSTALLFOLDER]"
                   Permanent="no" Part="last" Action="set" System="yes" />
    </Component>

    <!-- Main feature -->
    <Feature Id="ProductFeature" Title="Wendy Tools" Level="1">
      <ComponentGroupRef Id="ProductComponents" />
      <ComponentRef Id="PathEnv" />
    </Feature>

  </Package>
</Wix>
