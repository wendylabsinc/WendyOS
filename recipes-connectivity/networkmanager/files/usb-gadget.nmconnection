[connection]
id=usb-gadget
uuid=12345678-1234-1234-1234-123456789abc
type=ethernet
interface-name=usb0
autoconnect=true
autoconnect-priority=100
wait-device-timeout=60000

[ethernet]
mac-address-blacklist=

[ipv4]
method=manual
address1=192.168.7.1/24
dns-search=
# Static IP for USB gadget - host should use 192.168.7.2 or auto-config

[ipv6]
method=link-local
addr-gen-mode=stable-privacy

[proxy]
