[Unit]
Description=WendyOS Dev Registry Image Import (First Boot)
Documentation=https://github.com/wendylabsinc/containerd-registry
After=containerd.service
Requires=containerd.service
# Only run if the registry image doesn't exist yet
ConditionPathExists=!/var/lib/wendyos/dev-registry-imported
# And only if the archive exists
ConditionPathExists=/usr/share/wendyos/offline-images/containerd-registry.tar

[Service]
Type=oneshot
# Import the registry image into containerd's default namespace
ExecStartPre=/bin/mkdir -p /var/lib/wendyos
ExecStart=/usr/bin/ctr -n default images import /usr/share/wendyos/offline-images/containerd-registry.tar
# Re-tag to the expected name for consistency
ExecStartPost=/bin/sh -c '/usr/bin/ctr -n default images tag ghcr.io/wendylabsinc/containerd-registry:1.2.0 wendyos/containerd-registry:v1.2.0 || true'
ExecStartPost=/bin/sh -c '/usr/bin/ctr -n default images tag wendyos/containerd-registry:v1.2.0 wendyos/containerd-registry:latest || true'
# Protect image from garbage collection
ExecStartPost=/bin/sh -c '/usr/bin/ctr -n default images label wendyos/containerd-registry:v1.2.0 containerd.io/gc.root=true || true'
# Mark as imported so we don't run again
ExecStartPost=/bin/touch /var/lib/wendyos/dev-registry-imported
RemainAfterExit=yes
StandardOutput=journal
StandardError=journal

[Install]
WantedBy=multi-user.target
