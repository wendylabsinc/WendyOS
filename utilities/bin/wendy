#!/usr/bin/env bash
set -euo pipefail

if [[ -t 2 ]]; then
  bold=$'\033[1m'
  dim=$'\033[2m'
  green=$'\033[32m'
  cyan=$'\033[36m'
  reset=$'\033[0m'
else
  bold=""
  dim=""
  green=""
  cyan=""
  reset=""
fi

display_repo_path() {
  local path="$1"
  local repo_root="$2"
  local repo_name
  repo_name="$(basename "$repo_root")"

  case "$path" in
    "$repo_root"/*)
      printf '%s/%s' "$repo_name" "${path#"$repo_root"/}"
      ;;
    *)
      printf '%s' "$path"
      ;;
  esac
}

print_padded_line() {
  local text="$1"
  local style="${2:-}"
  local width="$3"
  local right_padding=$((width - ${#text}))

  if ((right_padding < 0)); then
    right_padding=0
  fi

  printf '    %s%s%s%*s    \n' "$style" "$text" "$reset" "$right_padding" ""
}

print_found_message() {
  local path="$1"
  local title='Running development version of wendy:'
  local width="${#title}"
  local divider

  if ((${#path} > width)); then
    width="${#path}"
  fi

  printf -v divider '%*s' "$width" ''
  divider="${divider// /━}"

  {
    printf '\n'
    printf '    %s%s%s    \n' "$dim" "$divider" "$reset"
    print_padded_line "$title" "$bold$green" "$width"
    print_padded_line '' '' "$width"
    print_padded_line "$path" "$cyan" "$width"
    printf '    %s%s%s    \n' "$dim" "$divider" "$reset"
    printf '\n'
  } >&2
}

resolve_path() {
  local path="$1"
  local path_dir
  local path_name

  path_dir="$(cd -P "$(dirname "$path")" >/dev/null 2>&1 && pwd -P)" || return 1
  path_name="$(basename "$path")"

  printf '%s/%s' "$path_dir" "$path_name"
}

resolve_wrapper_path() {
  local source_path="${BASH_SOURCE[0]}"
  local path_entry
  local candidate

  if [[ "$source_path" == */* ]]; then
    resolve_path "$source_path"
    return
  fi

  local old_ifs="$IFS"
  IFS=':'
  for path_entry in ${PATH:-}; do
    candidate="${path_entry:-.}/$source_path"
    if [[ -f "$candidate" && -x "$candidate" ]]; then
      IFS="$old_ifs"
      resolve_path "$candidate"
      return
    fi
  done
  IFS="$old_ifs"

  return 1
}

path_without_wrapper() {
  local wrapper_path="$1"
  local path_entry
  local candidate
  local filtered_path=""

  local old_ifs="$IFS"
  IFS=':'
  for path_entry in ${PATH:-}; do
    candidate="${path_entry:-.}/wendy"
    if [[ -n "$wrapper_path" && -e "$candidate" && "$candidate" -ef "$wrapper_path" ]]; then
      continue
    fi

    if [[ -z "$filtered_path" ]]; then
      filtered_path="$path_entry"
    else
      filtered_path="$filtered_path:$path_entry"
    fi
  done
  IFS="$old_ifs"

  printf '%s' "$filtered_path"
}

find_installed_wendy() {
  local path_entry
  local candidate
  local resolved_candidate

  local old_ifs="$IFS"
  IFS=':'
  for path_entry in ${PATH:-}; do
    candidate="${path_entry:-.}/wendy"
    if [[ ! -f "$candidate" || ! -x "$candidate" ]]; then
      continue
    fi

    IFS="$old_ifs"
    resolved_candidate="$(resolve_path "$candidate")" || resolved_candidate="$candidate"
    printf '%s' "$resolved_candidate"
    return 0
  done
  IFS="$old_ifs"

  return 1
}

wrapper_path="$(resolve_wrapper_path)" || wrapper_path=""
fallback_path="$(path_without_wrapper "$wrapper_path")"

dir="$(pwd -P)"

while true; do
  candidate="$dir/go/bin/wendy"

  if [[ -d "$dir/go/cmd/wendy" ]]; then
    pretty_candidate="$(display_repo_path "$candidate" "$dir")"
    print_found_message "$pretty_candidate"
    if [[ "$(uname -s)" == "Darwin" ]]; then
      export CGO_LDFLAGS="${CGO_LDFLAGS:+$CGO_LDFLAGS }-Wl,-no_warn_duplicate_libraries"
    fi
    (cd "$dir/go" && go build -o bin/wendy ./cmd/wendy)
    exec "$candidate" "$@"
  fi

  parent="$(dirname "$dir")"
  if [[ "$parent" == "$dir" ]]; then
    break
  fi

  dir="$parent"
done

if installed_wendy="$(PATH="$fallback_path" find_installed_wendy)"; then
  export PATH="$fallback_path"
  exec "$installed_wendy" "$@"
fi

echo "wendy: could not find development wendy above $(pwd -P) or installed wendy on PATH" >&2
exit 127
